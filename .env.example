PORT=4000
NODE_ENV=development

# Postgres (docker-compose sets this for the api service)
DATABASE_URL=postgres://extraordinary:extraordinary@db:5432/extraordinarylife

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Admin login (not stored in database)
ADMIN_EMAIL=admin@extraordinarylife.ng
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin
ADMIN_PHONE=+234 800 000 0001
ADMIN_ORGANISATION=Extraordinary Life

# Frontend URL for CORS (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3456,http://127.0.0.1:3456
